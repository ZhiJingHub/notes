{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "paths": {
      "vitepress": ["./node_modules/vitepress/types"]
    }
  },
  "include": [
    "doc/.vitepress/**/*.ts",
    "doc/.vitepress/**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "doc/.vitepress/dist",
    "doc/.vitepress/cache"
  ]
}
