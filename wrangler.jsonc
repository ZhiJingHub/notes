{
  "name": "notes",
  "main": "worker.js",
  "compatibility_date": "2025-12-31",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "doc/.vitepress/dist",
    "binding": "ASSETS"
  },
  "build": {
    "command": "pnpm install && pnpm run build"
  },
  "no_bundle": true,
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  }
}
